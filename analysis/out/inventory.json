      ],
      "views": {
        "v_event_summary": "SELECT\n    node_id,\n    category,\n    COUNT(*) AS event_count,\n    MAX(timestamp) AS last_event\nFROM events\nWHERE timestamp >= datetime('now', '-24 hours')\nGROUP BY node_id, category",
        "v_node_status": "SELECT\n    n.node_id,\n    n.node_name,\n    n.node_type,\n    n.zone,\n    n.status,\n    n.battery,\n    n.wifi_rssi,\n    n.last_seen,\n    CAST((julianday('now') - julianday(n.last_seen)) * 86400 AS INTEGER) AS seconds_since_seen,\n    n.firmware_version\nFROM nodes n",
        "v_pending_commands": "SELECT\n    c.command_id,\n    c.node_id,\n    c.command_type,\n    c.category,\n    c.params_json,\n    c.issued_at\nFROM commands c\nWHERE c.status = 'pending'\nORDER BY c.issued_at ASC",
        "v_recent_alerts": "SELECT\n    e.event_id,\n    e.node_id,\n    n.node_name,\n    n.zone,\n    e.event_type,\n    e.priority,\n    e.data_json,\n    e.timestamp\nFROM events e\nJOIN nodes n ON e.node_id = n.node_id\nWHERE e.priority IN ('high','critical')\n  AND e.timestamp >= datetime('now', '-24 hours')\nORDER BY e.timestamp DESC"
      }
    },
