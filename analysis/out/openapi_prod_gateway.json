{
  "components": {
    "schemas": {
      "CommandRequest": {
        "properties": {
          "arguments": {
            "additionalProperties": true,
            "title": "Arguments",
            "type": "object"
          },
          "category": {
            "enum": [
              "control",
              "configuration",
              "maintenance",
              "power"
            ],
            "title": "Category",
            "type": "string"
          },
          "command_type": {
            "title": "Command Type",
            "type": "string"
          },
          "dry_run": {
            "default": false,
            "title": "Dry Run",
            "type": "boolean"
          },
          "issued_by": {
            "default": "gateway",
            "title": "Issued By",
            "type": "string"
          },
          "timeout_ms": {
            "maximum": 600000.0,
            "minimum": 100.0,
            "title": "Timeout Ms",
            "type": "integer"
          }
        },
        "required": [
          "command_type",
          "category",
          "timeout_ms"
        ],
        "title": "CommandRequest",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
