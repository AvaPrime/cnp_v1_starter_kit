# CNP Gateway — Environment Variable Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is in .gitignore.
#
# Audit addition P0-07: this file was missing entirely.
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth ──────────────────────────────────────────────────────────────────────

# Bootstrap token: shared secret used by nodes before they receive a per-node
# secret. All nodes use this token during their first /api/node/hello.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
BOOTSTRAP_TOKEN=changeme-generate-a-real-token-before-production

# Admin token: protects /api/fleet/status, /api/nodes/{id}/provision,
# and /api/nodes/{id}/rotate-secret. Must be different from BOOTSTRAP_TOKEN.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=changeme-generate-a-different-real-token

# ── Database ──────────────────────────────────────────────────────────────────

# Path to the SQLite database file. Use an absolute path in production.
# For Docker deployments, mount a volume here.
GATEWAY_DB_PATH=./cnp_gateway.db

# Per-query timeout in seconds. Requests that exceed this return 503.
DB_QUERY_TIMEOUT_SEC=3.0

# ── MQTT broker ───────────────────────────────────────────────────────────────

MQTT_BROKER_HOST=127.0.0.1
MQTT_BROKER_PORT=1883

# Leave empty for unauthenticated MQTT (local dev only).
# In production, always use TLS + credentials — see TLS_SETUP.md.
MQTT_USERNAME=
MQTT_PASSWORD=

# ── Gateway identity ──────────────────────────────────────────────────────────

CNP_GATEWAY_ID=codessa-gateway-local

# Seconds after last heartbeat before a node is marked offline.
CNP_OFFLINE_AFTER_SECONDS=180

# ── Network security ──────────────────────────────────────────────────────────

# Comma-separated IPs or CIDRs of trusted reverse proxies.
# X-Forwarded-For is only trusted from these addresses.
# Leave empty if running directly (no reverse proxy).
# Example: TRUSTED_PROXIES=10.0.0.0/8,172.16.0.1
TRUSTED_PROXIES=

# ── Observability (Phase 3) ───────────────────────────────────────────────────

# Redis URL for shared rate limiting across workers.
# Leave empty to use in-memory rate limiting (dev only).
# REDIS_URL=redis://localhost:6379/0
