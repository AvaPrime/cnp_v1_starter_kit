    "schemas": {
      "cnp_v1_schemas.json": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "definitions": {
          "command": {
            "allOf": [
              {
                "$ref": "#/definitions/message_envelope"
              }
            ],
            "description": "Gateway \u2192 node command",
            "properties": {
              "message_type": {
                "const": "command"
              },
              "payload": {
                "properties": {
                  "category": {
                    "enum": [
                      "control",
                      "configuration",
                      "maintenance",
                      "power"
                    ],
                    "type": "string"
                  },
                  "command_id": {
                    "type": "string"
                  },
                  "command_type": {
                    "type": "string"
                  },
                  "params": {
                    "type": "object"
                  },
                  "timeout_ms": {
                    "type": "integer"
                  }
                },
                "required": [
                  "command_id",
                  "command_type",
                  "category"
                ],
                "type": "object"
              }
            }
          },
          "command_result": {
            "allOf": [
              {
                "$ref": "#/definitions/message_envelope"
              }
            ],
            "description": "Acknowledgment sent after executing a command",
            "properties": {
              "message_type": {
                "const": "command_result"
              },
              "payload": {
                "properties": {
                  "command_id": {
                    "type": "string"
                  },
                  "detail": {
                    "type": "string"
                  },
                  "status": {
                    "enum": [
                      "executed",
                      "failed",
                      "rejected",
                      "queued"
                    ],
                    "type": "string"
                  }
                },
                "required": [
                  "command_id",
                  "status"
                ],
                "type": "object"
              }
            }
          },
          "error": {
            "allOf": [
              {
                "$ref": "#/definitions/message_envelope"
              }
            ],
            "description": "Node-side error report",
            "properties": {
              "message_type": {
                "const": "error"
              },
              "payload": {
                "properties": {
                  "error_code": {
                    "type": "string"
                  },
                  "error_msg": {
                    "type": "string"
                  },
                  "recoverable": {
                    "type": "boolean"
                  }
                },
                "required": [
                  "error_code",
                  "error_msg"
                ],
                "type": "object"
              }
            }
          },
          "event": {
            "allOf": [
              {
                "$ref": "#/definitions/message_envelope"
              }
            ],
            "description": "Something meaningful happened",
            "properties": {
              "message_type": {
                "const": "event"
              },
              "payload": {
                "properties": {
                  "category": {
                    "enum": [
                      "telemetry",
                      "alert",
                      "interaction",
                      "system",
                      "security",
                      "power"
                    ],
                    "type": "string"
                  },
                  "data": {
                    "type": "object"
                  },
                  "event_id": {
                    "type": "string"
                  },
                  "event_type": {
                    "type": "string"
                  },
                  "priority": {
                    "enum": [
                      "low",
                      "normal",
                      "high",
                      "critical"
                    ],
                    "type": "string"
                  }
                },
                "required": [
                  "event_id",
                  "event_type",
                  "category",
                  "priority",
                  "data"
                ],
                "type": "object"
              }
            }
          },
          "heartbeat": {
            "allOf": [
              {
                "$ref": "#/definitions/message_envelope"
              }
            ],
            "description": "Sent periodically to confirm node is alive",
            "properties": {
              "message_type": {
                "const": "heartbeat"
              },
              "payload": {
                "properties": {
                  "battery": {
                    "maximum": 100,
                    "minimum": 0,
                    "type": "number"
                  },
                  "status": {
                    "enum": [
                      "online",
                      "degraded"
                    ],
                    "type": "string"
                  },
                  "uptime_sec": {
                    "type": "integer"
                  },
                  "wifi_rssi": {
                    "type": "integer"
                  }
                },
                "required": [
                  "status",
                  "uptime_sec"
                ],
                "type": "object"
              }
            }
          },
          "hello": {
            "allOf": [
              {
                "$ref": "#/definitions/message_envelope"
              }
            ],
            "description": "Sent once on boot \u2014 announces identity and capabilities",
            "properties": {
              "message_type": {
                "const": "hello"
              },
              "payload": {
                "properties": {
                  "capabilities": {
                    "properties": {
                      "actuators": {
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      },
                      "connectivity": {
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      },
                      "power_mode": {
                        "enum": [
                          "usb",
                          "battery",
                          "solar"
                        ],
                        "type": "string"
                      },
                      "sensors": {
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      }
                    },
                    "type": "object"
                  },
                  "firmware_version": {
                    "type": "string"
                  },
                  "node_name": {
                    "type": "string"
                  },
                  "node_type": {
                    "enum": [
                      "sensor",
                      "actuator",
                      "hybrid",
                      "gateway"
                    ],
                    "type": "string"
                  },
                  "zone": {
                    "type": "string"
                  }
                },
                "required": [
                  "node_name",
                  "node_type",
                  "zone",
                  "firmware_version",
                  "capabilities"
                ],
                "type": "object"
              }
            }
          },
          "message_envelope": {
            "description": "Universal wrapper for every CNP message",
            "properties": {
              "message_type": {
                "enum": [
                  "hello",
                  "heartbeat",
                  "state_update",
                  "event",
                  "command_result",
                  "error",
                  "register_ack",
                  "config_update",
                  "command",
                  "ping",
                  "reboot",
                  "sleep"
                ],
                "type": "string"
              },
              "node_id": {
                "pattern": "^cnp-[a-z0-9]+-[a-z0-9]+-[0-9]{2}$",
                "type": "string"
              },
              "payload": {
                "type": "object"
              },
              "protocol": {
                "const": "CNPv1",
                "type": "string"
              },
              "timestamp": {
                "format": "date-time",
                "type": "string"
              }
            },
            "required": [
              "protocol",
              "message_type",
              "node_id",
              "timestamp",
              "payload"
            ],
            "type": "object"
          },
          "register_ack": {
            "allOf": [
              {
                "$ref": "#/definitions/message_envelope"
              }
            ],
            "description": "Gateway confirms successful node registration",
            "properties": {
              "message_type": {
                "const": "register_ack"
              },
              "payload": {
                "properties": {
                  "config": {
                    "properties": {
                      "heartbeat_interval_sec": {
                        "default": 30,
                        "type": "integer"
                      },
                      "permissions": {
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      },
                      "report_interval_sec": {
                        "default": 60,
                        "type": "integer"
                      },
                      "zone": {
                        "type": "string"
                      }
                    },
                    "type": "object"
                  },
                  "registered": {
                    "type": "boolean"
                  }
                },
                "required": [
                  "registered",
                  "config"
                ],
                "type": "object"
              }
            }
          },
          "state_update": {
            "allOf": [
              {
                "$ref": "#/definitions/message_envelope"
              }
            ],
            "description": "Full state snapshot of the node",
            "properties": {
              "message_type": {
                "const": "state_update"
              },
              "payload": {
                "properties": {
                  "battery": {
                    "type": "number"
                  },
                  "errors": {
                    "items": {
                      "type": "string"
                    },
                    "type": "array"
                  },
                  "last_seen": {
                    "format": "date-time",
                    "type": "string"
                  },
                  "status": {
                    "enum": [
                      "online",
                      "offline",
                      "degraded"
                    ],
                    "type": "string"
                  },
                  "uptime_sec": {
                    "type": "integer"
                  },
                  "wifi_rssi": {
                    "type": "integer"
                  }
                },
                "required": [
                  "status"
                ],
                "type": "object"
              }
            }
          }
        },
        "examples": {
          "command_relay": {
            "message_type": "command",
            "node_id": "cnp-lab-relay-01",
            "payload": {
              "category": "control",
              "command_id": "cmd-000001",
              "command_type": "set_relay",
              "params": {
                "state": "on"
              },
              "timeout_ms": 5000
            },
            "protocol": "CNPv1",
            "timestamp": "2026-03-18T10:07:00Z"
          },
          "event_alert": {
            "message_type": "event",
            "node_id": "cnp-entry-motion-01",
            "payload": {
              "category": "alert",
              "data": {
                "motion": true
              },
              "event_id": "evt-000002",
              "event_type": "motion_detected",
              "priority": "high"
            },
            "protocol": "CNPv1",
            "timestamp": "2026-03-18T10:06:00Z"
          },
          "event_telemetry": {
            "message_type": "event",
            "node_id": "cnp-office-temp-01",
            "payload": {
              "category": "telemetry",
              "data": {
                "humidity_pct": 61,
                "temperature_c": 27.4
              },
              "event_id": "evt-000001",
              "event_type": "temperature_reading",
              "priority": "normal"
            },
            "protocol": "CNPv1",
            "timestamp": "2026-03-18T10:05:00Z"
          },
          "hello": {
            "message_type": "hello",
            "node_id": "cnp-office-temp-01",
            "payload": {
              "capabilities": {
                "actuators": [],
                "connectivity": [
                  "wifi"
                ],
                "power_mode": "usb",
                "sensors": [
                  "temperature",
                  "humidity"
                ]
              },
              "firmware_version": "1.0.0",
              "node_name": "Office Climate Node",
              "node_type": "sensor",
              "zone": "office"
            },
            "protocol": "CNPv1",
            "timestamp": "2026-03-18T10:00:00Z"
          }
        },
        "title": "Codessa Node Protocol v1 \u2014 Message Schemas",
        "version": "CNPv1"
      }
    }
  },
